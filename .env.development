# Dev API: run `npm run dev:api` in a second terminal, then `npm run dev`.
Vite proxies /api to http://127.0.0.1:8080 (local PHP with your backend files).

# Use production API instead (only if master_data.php is deployed there):
VITE_DEV_API_REMOTE=true

# City autocomplete (Geoapify): copy backend/api/geo_config.example.php → geo_config.php
# OR set key here for direct browser fallback when PHP proxy is unavailable:
# VITE_CITY_API_KEY=your_geoapify_api_key
